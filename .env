# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uptime_monitor

# API Configuration
PORT=3000

# Worker Configuration
CHECK_INTERVAL=30000
MAX_CONCURRENT_CHECKS=10

